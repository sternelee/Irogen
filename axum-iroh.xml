                    success: response.success,
                    result: response.result,
                    error: response.error,
                })),
                Err(e) => Err((
                    StatusCode::INTERNAL_SERVER_ERROR,
                    format!("Failed to execute MCP tool: {}", e),
                )),
            }
        })
    })
