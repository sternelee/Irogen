{
  "name": "riterm-browser",
  "version": "0.1.0",
  "description": "RiTerm browser WASM client",
  "main": "pkg/riterm_browser.js",
  "types": "pkg/riterm_browser.d.ts",
  "scripts": {
    "build": "wasm-pack build --target web --out-dir pkg",
    "dev": "wasm-pack build --target web --out-dir pkg --dev",
    "serve": "python3 -m http.server 8080",
    "build:wasm": "wasm-pack build ./ --dev --weak-refs --reference-types -t bundler -d pkg",
    "build:wasm:release": "wasm-pack build ./ --release -t bundler -d pkg",
    "clean": "rm -rf pkg"
  },
  "devDependencies": {
    "wasm-pack": "^0.12.1"
  }
}
