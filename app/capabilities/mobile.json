{
  "$schema": "../gen/schemas/capabilities.json",
  "identifier": "mobile-capability",
  "windows": [
    "main"
  ],
  "platforms": [
    "iOS",
    "android"
  ],
  "permissions": [
    "barcode-scanner:allow-scan",
    "barcode-scanner:allow-cancel",
    "barcode-scanner:default",
    "notification:default",
    "clipboard-manager:default",
    "http:default",
    "os:default"
  ]
}
